        }
      },
      {
        "name": "list_domains",
        "description": "List sending domains configured in Resend",
        "method": "GET",
        "path": "/domains",
        "params": {}
      }
    ]
  },
  {
    "slug": "twilio",
    "name": "Twilio",
    "description": "Send SMS messages and manage Twilio phone numbers",
    "category": "communication",
    "source_repo": "https://github.com/aerostackdev/aerostack-mcp/tree/main/workers/mcp-twilio",
    "auth": {
      "type": "basic",
      "envs": ["TWILIO_ACCOUNT_SID", "TWILIO_AUTH_TOKEN"],
      "notes": "Use Basic auth: base64('TWILIO_ACCOUNT_SID:TWILIO_AUTH_TOKEN'). API base: https://api.twilio.com/2010-04-01/Accounts/{TWILIO_ACCOUNT_SID}"
    },
    "api_base": "https://api.twilio.com/2010-04-01",
    "tools": [
      {
        "name": "send_sms",
        "description": "Send an SMS message via Twilio",
        "method": "POST",
        "path": "/Accounts/{account_sid}/Messages.json",
        "params": {
          "to": { "type": "string", "description": "Recipient phone number in E.164 format (e.g. +14155551234)", "required": true },
          "from": { "type": "string", "description": "Twilio phone number in E.164 format (must be in your account)", "required": true },
