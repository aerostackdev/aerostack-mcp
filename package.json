{
  "name": "@aerostack/mcp-catalog",
  "version": "1.0.0",
  "description": "Aerostack MCP server catalog — 654 entries, 37 Workers, 14 proxies",
  "type": "module",
  "scripts": {
    "deploy:dev": "DEPLOY_ENV=staging node scripts/deploy-all.mjs",
    "deploy:prod": "DEPLOY_ENV=production node scripts/deploy-all.mjs",
