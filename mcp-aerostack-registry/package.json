{
  "name": "aerostack-mcp-registry",
  "description": "Discovery MCP server — search and call any Aerostack function, MCP, or skill",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "aerostack dev",
    "build": "npx esbuild src/index.ts --bundle --outfile=dist/index.js --format=esm --minify --external:node:* --external:cloudflare:*",
    "deploy": "aerostack deploy mcp aerostack-registry",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241112.0",
    "esbuild": "^0.21.0",
    "typescript": "^5.5.4"
  }
}
