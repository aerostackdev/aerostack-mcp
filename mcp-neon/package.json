{
  "name": "aerostack-mcp-neon",
  "description": "MCP server for Neon serverless PostgreSQL — query and write data from AI agents",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "aerostack dev",
    "build": "npx esbuild src/index.ts --bundle --outfile=dist/index.js --format=esm --minify --external:node:* --external:cloudflare:*",
    "deploy": "aerostack deploy mcp neon",
    "test": "vitest run"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241112.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2"
  }
}
