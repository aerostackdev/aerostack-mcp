{
  "id": "shopify",
  "name": "Shopify",
  "tier": "proxy",
  "status": "live",
  "proxy_url": "https://{SHOPIFY_DOMAIN}/api/mcp",
  "auth_type": "bearer",
  "category": "Ecommerce",
  "description": "Products, orders, customers, inventory via Shopify's official MCP",
  "env_vars": [
    {
      "key": "SHOPIFY_DOMAIN",
      "required": true,
      "secret": false,
      "description": "Your Shopify store domain (e.g. mystore.myshopify.com)",
      "how_to_set": "Found in your Shopify admin URL"
    },
    {
      "key": "SHOPIFY_ACCESS_TOKEN",
      "required": true,
      "secret": true,
      "description": "Shopify Admin API Access Token",
      "how_to_set": "Shopify admin → Settings → Apps → Develop apps → Create app → Admin API access token"
    }
  ],
  "capability_manifest": {
    "capabilities": [
      "general"
    ],
    "data_types": [
      "order",
      "customer",
      "product"
    ],
    "auth_required": "bearer",
    "triggers_available": [],
    "pairs_with": [
      "slack",
      "email",
      "webhook"
    ],
    "best_for": [
      "ecommerce operations"
    ],
    "not_suitable_for": [
      "real-time event streaming (no webhook support)",
      "complex multi-step workflows (limited tool set)"
    ]
  }
}
